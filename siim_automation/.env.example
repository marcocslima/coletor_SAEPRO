# Copie este arquivo para .env e preencha com suas credenciais reais.
SIIM_URL=https://siim21.cijun.sp.gov.br/CA
SIIM_ORGAO=PREFEITURA DO MUNICÍPIO DE JUNDIAÍ
SIIM_USER=seu_usuario@jundiai.sp.gov.br
SIIM_PASSWORD=sua_senha_aqui

# Opcional: pasta onde os PDFs serão salvos. Se vazio, usa ~/Downloads.
DOWNLOAD_DIR=/home/ubuntu/Downloads

# Opcional: false para ver o navegador; true para executar em segundo plano.
HEADLESS=false

# Opcional: caminho para o Chrome do sistema.
# CHROME_PATH=/usr/bin/google-chrome

# Projetos fixos separados por vírgula (usado se GOOGLE_SHEET_ID não estiver configurado).
PROJECTS=SAEPRO2025/6485,SAEPRO2025/6865,SAEPRO2025/6884

# --- Google Sheets (opcional) ---
# Se configurado, substitui PROJECTS pela lista da planilha.
# GOOGLE_SHEET_CREDENTIALS=credentials/google-sheets.json
# GOOGLE_SHEET_ID=1abc123xxx...

# --- Google Sheets: aba de configuração (opcional) ---
# Aba da planilha com a lista de documentos a baixar.
# Coluna A: nome do documento, Coluna B: "x" para baixar.
# Se não existir, baixa apenas PROJETO SIMPLIFICADO.
# GOOGLE_SHEET_CONFIG_TAB=config

# --- Google Drive (opcional) ---
# Se configurado, envia os PDFs baixados para esta pasta do Drive e apaga o local.
# Os arquivos sao organizados em subpastas por projeto.
# Requer que a Drive API esteja ativada no GCP e a pasta compartilhada com a service account.
# GOOGLE_DRIVE_FOLDER_ID=1abc123xxx...
