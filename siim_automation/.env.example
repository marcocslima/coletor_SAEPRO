# Copie este arquivo para .env e preencha com suas credenciais reais.
SIIM_URL=https://siim21.cijun.sp.gov.br/CA
SIIM_ORGAO=PREFEITURA DO MUNICÍPIO DE JUNDIAÍ
SIIM_USER=seu_usuario@jundiai.sp.gov.br
SIIM_PASSWORD=sua_senha_aqui

# Opcional: pasta onde os PDFs serão salvos. Se vazio, usa ~/Downloads.
DOWNLOAD_DIR=/home/ubuntu/Downloads

# Opcional: false para ver o navegador; true para executar em segundo plano.
HEADLESS=false

# Opcional: projetos separados por vírgula.
PROJECTS=SAEPRO2025/6485,SAEPRO2025/6865,SAEPRO2025/6884
